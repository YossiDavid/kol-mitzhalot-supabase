# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# App URL – Production: https://kol-mitzhalot.org.il
# Vercel Preview: uses VERCEL_URL automatically (e.g. https://xxx-yyy.vercel.app)
NEXT_PUBLIC_APP_URL=https://kol-mitzhalot.org.il

# Supabase Auth: ב-Dashboard > Authentication > URL Configuration
#   Site URL: חייב להתאים לדומיין האמיתי! אם הכפתור במייל מפנה ל-localhost מפרודקשן –
#     להחליף ל: https://kol-mitzhalot-supabase.vercel.app (או https://kol-mitzhalot.org.il)
#   Redirect URLs: https://kol-mitzhalot-supabase.vercel.app/**, https://*.vercel.app/**, http://localhost:3000/**

# Micropay (OTP)
MICROPAY_URL=
MICROPAY_TOKEN=

# אדמין (אופציונלי)
# SUPABASE_SERVICE_ROLE_KEY=
