# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# App URL – Production: https://kol-mitzhalot.org.il
# Vercel Preview: uses VERCEL_URL automatically (e.g. https://xxx-yyy.vercel.app)
NEXT_PUBLIC_APP_URL=https://kol-mitzhalot.org.il

# Supabase Auth: ב-Dashboard > Authentication > URL Configuration
#   Site URL: חייב להתאים לדומיין האמיתי! אם הכפתור במייל מפנה ל-localhost מפרודקשן –
#     להחליף ל: https://kol-mitzhalot-supabase.vercel.app (או https://kol-mitzhalot.org.il)
#   Redirect URLs: https://kol-mitzhalot-supabase.vercel.app/**, https://*.vercel.app/**, http://localhost:3000/**

# Micropay (OTP)
MICROPAY_URL=
MICROPAY_TOKEN=
# סוג שליחה: sms | vms (שיחה קולית) | auto (מיקרופיי בוחרים). אם השיחה לא מגיעה נסה auto או הגדר VMSFROM.
# MICROPAY_OTP_TYPE=vms
# מספר שיציג בשיחה קולית (חלק מהספקים דורשים; אם חסר – שיחה ממספר חסוי)
# MICROPAY_VMSFROM=

# Rate limit: מקסימום שליחות קוד OTP לשעה (לכל טלפון+IP). ברירת מחדל 10, מקסימום 100.
# OTP_RATE_LIMIT_PER_HOUR=10

# אדמין (אופציונלי)
# SUPABASE_SERVICE_ROLE_KEY=

# SendGrid — שליחת הצעות שידוך מהלוח (API route)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL חייב להתאים לכתובת/דומיין מאומת ב-SendGrid (Settings → Sender Authentication).
# אחרת תקבלו 403: "from address does not match a verified Sender Identity".
# אם מתקבלת תשובה חיובית אבל אין מייל ואין רשומה ב-Email Activity: בדקו ש-Sandbox Mode כבוי
# (Settings → Mail Settings). במצב Sandbox הבקשה עשויה להיראות מוצלחת בלי משלוח אמיתי.
# נמעני הצעת שידוך: מיילי מנהלי הכרטיסים מ-Supabase Auth (לא המשתמש המחובר כשדכן).
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=קול מצהלות
# תבנית Dynamic (HTML) — מזהה מ-SendGrid → Dynamic Templates → ה-ID נראה כמו d-xxxxxxxx
# אם לא מוגדר — נשלח טקסט גולמי בלבד
# SENDGRID_TEMPLATE_ID_SHIDDUCH_OFFER=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
